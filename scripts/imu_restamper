#!/usr/bin/env python3
"""
Republish /ouster/imu with the ROS receive time as stamp.

The Ouster uses TIME_FROM_PTP_1588. While PTP is converging the sensor
timestamps can lag the system clock by tens of seconds, causing
robot_localization to reject every measurement. This node strips the sensor
timestamp and replaces it with the time the message was received.

Input:  /ouster/imu   (sensor_msgs/Imu, BEST_EFFORT)
Output: /ouster/imu_restamped (sensor_msgs/Imu, RELIABLE)
"""
import rclpy
from rclpy.node import Node
from rclpy.qos import QoSProfile, QoSReliabilityPolicy, QoSHistoryPolicy

from sensor_msgs.msg import Imu


class ImuRestamper(Node):
    def __init__(self):
        super().__init__('imu_restamper')

        be = QoSProfile(
            reliability=QoSReliabilityPolicy.BEST_EFFORT,
            history=QoSHistoryPolicy.KEEP_LAST,
            depth=5,
        )
        self._pub = self.create_publisher(Imu, '/ouster/imu_restamped', 10)
        self._sub = self.create_subscription(
            Imu, '/ouster/imu', self._cb, be)
        self.get_logger().info('IMU restamper ready.')

    def _cb(self, msg: Imu):
        msg.header.stamp = self.get_clock().now().to_msg()
        self._pub.publish(msg)


def main(args=None):
    rclpy.init(args=args)
    node = ImuRestamper()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
