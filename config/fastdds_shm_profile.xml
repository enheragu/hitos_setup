<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Fast DDS profile for the HITOS large-data PUBLISHER processes (os_driver,
  visible_camera, lwir_camera, buffer_compositor), applied per process via
  FASTRTPS_DEFAULT_PROFILES_FILE (launch additional_env / scoped
  SetEnvironmentVariable). See memory project_shm_rollout.

  32 MB SHM segment so the large samples (visible 5.76 MB, calib cloud 3.8 MB)
  travel over shared memory instead of fragmented UDP loopback. max_message_size
  raised so SHM is not bypassed for big samples. Segment is RESIDENT in /dev/shm
  (~32 MB per process) — applied only to the ~4 big publishers, never globally.
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <!-- INERT (builtin transports) while we pursue the data-reduction path. SHM
         works for simple participants but does NOT engage for the compositor's
         raw/generic multi-subscription setup (it stayed on UDP at 86% CPU), so
         it gives no benefit here for now. Wiring kept; to re-enable, restore the
         SHM+UDP transport_descriptors + userTransports + useBuiltinTransports
         false. See memory project_shm_rollout. -->
    <participant profile_name="hitos_shm" is_default_profile="true">
      <rtps>
        <useBuiltinTransports>true</useBuiltinTransports>
      </rtps>
    </participant>
  </profiles>
</dds>
